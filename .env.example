# cp .env.example .env

LENDING_CLUB_CSV_PATH=/opt/airflow/data/lending_club.csv
TRAIN_END_DATE=2022-12-31
VAL_END_DATE=2023-06-30
AUTO_DATE_SPLIT=true
N_OPTUNA_TRIALS=10

# For Airflow containers:
APP_DB_HOST=postgres
# For host telegram_notifier.py use localhost (script maps postgres→localhost)
APP_DB_PORT=5432
APP_DB_NAME=credit_scoring
APP_DB_USER=ml_user
APP_DB_PASSWORD=ml_password

MLFLOW_TRACKING_URI=http://mlflow:5000

# Feature-drift alerts (required for Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
