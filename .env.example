# Copy to .env and adjust for local / docker usage

# Path to applications CSV (mounted into Airflow as /opt/airflow/data/...)
LENDING_CLUB_CSV_PATH=/opt/airflow/data/sample_applications.csv

# Application PostgreSQL
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=credit_scoring
APP_DB_USER=ml_user
APP_DB_PASSWORD=ml_password

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Optional Telegram alerts for drift
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
