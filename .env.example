# cp .env.example .env  — .env is gitignored, keep secrets here
# This template works for both local runs and Docker (compose overrides DB host)

# ---------- DATA ----------
LENDING_CLUB_CSV_PATH=/opt/airflow/data/lending_club.csv

# ---------- TRAINING ----------
TRAIN_END_DATE=2022-12-31
VAL_END_DATE=2023-06-30
AUTO_DATE_SPLIT=true
N_OPTUNA_TRIALS=15
MIN_AUC_FOR_REGISTRATION=0.70
CALIBRATION_METHOD=isotonic

# ---------- INGESTION (avoid OOM) ----------
PAYMENT_HISTORY_MAX_APPS=300000
PAYMENT_HISTORY_BATCH_SIZE=5000
PAYMENT_HISTORY_N_PER_LOAN=12
BUREAU_MAX_APPS=
BUREAU_BATCH_SIZE=10000
HISTORY_SAMPLE_STRATEGY=random

# ---------- FEATURE ENGINEERING (cold-start aware, weak PC) ----------
FE_NUMERICAL_BATCH_SIZE=100000
FE_BUREAU_BATCH_SIZE=100000
FE_AGGREGATION_BATCH_SIZE=100000
FE_TARGET_ENCODING_BATCH_SIZE=100000
FE_STAGING_WRITE_BATCH_SIZE=50000
# 400k = 300k with payments (75%) + 100k cold-start (25%)
# Empty = all 2.2M for full prod run
FE_MAX_APPS=400000

# ---------- DATABASE ----------
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=credit_scoring
APP_DB_USER=ml_user
APP_DB_PASSWORD=ml_password

# ---------- MLFLOW ----------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=./mlflow_artifacts

# ---------- TELEGRAM (optional) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
